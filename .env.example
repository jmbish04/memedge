# Cloudflare Account Credentials (for Drizzle Kit)
# Get these from your Cloudflare dashboard
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_DATABASE_ID=your_database_id_here
CLOUDFLARE_D1_TOKEN=your_api_token_here

# LLM API Keys (use wrangler secret put for production)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# Environment
NODE_ENV=development
