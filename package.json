{
  "name": "memedge",
  "version": "1.0.1",
  "description": "Advanced memory management system for LLM agents with Letta-inspired features",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./summaries": {
      "types": "./dist/summaries/index.d.ts",
      "import": "./dist/summaries/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "import": "./dist/tools/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:astro",
    "build:lib": "tsc",
    "build:astro": "astro check && astro build",
    "dev": "wrangler dev",
    "dev:astro": "astro dev",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build:lib",
    "types": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply memedge-db",
    "db:migrate:local": "wrangler d1 migrations apply memedge-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply memedge-db --remote",
    "db:studio": "drizzle-kit studio",
    "cf:create-db": "wrangler d1 create memedge-db"
  },
  "keywords": [
    "llm",
    "memory",
    "agent",
    "ai",
    "letta",
    "memgpt",
    "cloudflare",
    "workers",
    "durable-objects",
    "semantic-search",
    "embeddings",
    "summarization"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.35",
    "@ai-sdk/google": "^2.0.23",
    "@ai-sdk/openai": "^2.0.53",
    "@astrojs/check": "^0.9.0",
    "@astrojs/cloudflare": "^12.1.0",
    "@astrojs/react": "^3.6.2",
    "@astrojs/tailwind": "^5.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "ai": "^5.0.76",
    "astro": "^4.16.18",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "effect": "^3.18.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitest/ui": "^3.2.4",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "wrangler": "^3.99.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}